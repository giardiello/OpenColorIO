                </aces:fromCdlWorkingSpace>
            </aces:cdlWorkingSpace>
            <cdl:ASC_SOP>
                <cdl:Slope>1.12 1.04 0.94</cdl:Slope>
                <cdl:Offset>0.01 0.0 -0.01</cdl:Offset>
                <cdl:Power>1.0 1.0 1.0</cdl:Power>
